<form method="POST" action="/expenses" class="space-y-4">

  <input
    name="title"
    placeholder="Tên chi tiêu"
    class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400"
  />

  <div class="flex gap-4">
    <input
      name="amount"
      placeholder="Số tiền"
      class="w-1/2 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-400"
    />

    <select
      name="category"
      class="w-1/2 px-4 py-2 border rounded-lg"
    >
      <option>Ăn uống</option>
      <option>Di chuyển</option>
      <option>Giải trí</option>
    </select>
  </div>

  <button
    class="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600"
  >
    + Thêm chi tiêu
  </button>

</form>