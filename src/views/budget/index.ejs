<%- include('../components/sidebar') %>

<main class="pl-72 min-h-screen">
    <%- include('../components/topbar') %>

    <div class="px-14 pb-14 max-w-[1400px] mx-auto pt-8">
        
        <section class="mb-12">
            <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary to-primary-container p-10 text-white flex items-center justify-between shadow-2xl shadow-primary/20">
                <div class="relative z-10 max-w-xl">
                    <h3 class="text-3xl font-extrabold mb-3 leading-tight">Tuyệt vời! Bạn đang kiểm soát rất tốt.</h3>
                    <p class="text-white/80 text-lg leading-relaxed font-medium">Bạn đã tiết kiệm được <span class="text-white font-bold">2.400.000₫</span> so với kế hoạch tháng này. Hãy tiếp tục duy trì phong độ nhé!</p>
                    <div class="mt-8 flex space-x-4">
                        <button class="px-8 py-3 bg-white text-primary rounded-xl font-bold text-sm hover:shadow-lg transition-all active:scale-95">Xem chi tiết</button>
                        <button class="px-8 py-3 bg-white/20 backdrop-blur-md text-white rounded-xl font-bold text-sm hover:bg-white/30 border border-white/10 transition-all active:scale-95">Tải báo cáo</button>
                    </div>
                </div>
                <div class="hidden lg:block relative z-10 mr-10">
                    <div class="w-56 h-56 flex items-center justify-center bg-white/10 rounded-full backdrop-blur-2xl border border-white/20 shadow-inner">
                        <span class="material-symbols-outlined text-8xl" style="font-variation-settings: 'FILL' 1;">trending_up</span>
                    </div>
                </div>
                <div class="absolute -top-12 -right-12 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
                <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-primary-container/20 rounded-full blur-3xl"></div>
            </div>
        </section>

        <section class="grid grid-cols-1 md:grid-cols-12 gap-8">
            
            <div class="md:col-span-8 space-y-6">
                <div class="flex items-center justify-between mb-2">
                    <h4 class="text-xl font-bold text-on-surface">Ngân sách đang hoạt động</h4>
                    <button class="text-primary font-bold text-sm flex items-center hover:bg-primary-fixed/30 px-3 py-1.5 rounded-lg transition-all">
                        Tạo ngân sách mới
                        <span class="material-symbols-outlined ml-2 text-lg">add_circle</span>
                    </button>
                </div>
                
                <div class="space-y-4">
                    <div class="bg-white p-7 rounded-3xl shadow-sm border border-violet-100/50 group transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                        <div class="flex items-start justify-between mb-6">
                            <div class="flex items-center space-x-5">
                                <div class="w-14 h-14 rounded-2xl bg-orange-50 text-orange-500 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">restaurant</span>
                                </div>
                                <div>
                                    <p class="font-bold text-on-surface text-xl">Ăn uống & Nhà hàng</p>
                                    <p class="text-sm text-slate-400 font-medium">Còn lại 1.200.000₫</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-on-surface text-lg">3.800.000₫ <span class="text-slate-400 text-sm font-medium">/ 5.000.000₫</span></p>
                                <span class="text-[11px] font-extrabold text-orange-600 px-2.5 py-1 bg-orange-50 rounded-full uppercase tracking-tight mt-1 inline-block">Sắp chạm giới hạn</span>
                            </div>
                        </div>
                        <div class="h-2.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-orange-400 to-orange-500 rounded-full w-[76%]"></div>
                        </div>
                    </div>

                    <div class="bg-white p-7 rounded-3xl shadow-sm border border-violet-100/50 group transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                        <div class="flex items-start justify-between mb-6">
                            <div class="flex items-center space-x-5">
                                <div class="w-14 h-14 rounded-2xl bg-primary/5 text-primary flex items-center justify-center">
                                    <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">flight_takeoff</span>
                                </div>
                                <div>
                                    <p class="font-bold text-on-surface text-xl">Du lịch & Di chuyển</p>
                                    <p class="text-sm text-slate-400 font-medium">Còn lại 4.500.000₫</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-on-surface text-lg">1.500.000₫ <span class="text-slate-400 text-sm font-medium">/ 6.000.000₫</span></p>
                                <span class="text-[11px] font-extrabold text-primary px-2.5 py-1 bg-primary/5 rounded-full uppercase tracking-tight mt-1 inline-block">An toàn</span>
                            </div>
                        </div>
                        <div class="h-2.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="h-full bg-primary rounded-full w-[25%]"></div>
                        </div>
                    </div>

                    <div class="bg-white p-7 rounded-3xl shadow-sm border border-violet-100/50 group transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                        <div class="flex items-start justify-between mb-6">
                            <div class="flex items-center space-x-5">
                                <div class="w-14 h-14 rounded-2xl bg-red-50 text-error flex items-center justify-center">
                                    <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">shopping_bag</span>
                                </div>
                                <div>
                                    <p class="font-bold text-on-surface text-xl">Mua sắm cá nhân</p>
                                    <p class="text-sm text-error font-bold">Vượt quá 500.000₫</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-on-surface text-lg">3.500.000₫ <span class="text-slate-400 text-sm font-medium">/ 3.000.000₫</span></p>
                                <span class="text-[11px] font-extrabold text-white px-2.5 py-1 bg-error rounded-full uppercase tracking-tight mt-1 inline-block">Quá hạn mức</span>
                            </div>
                        </div>
                        <div class="h-2.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="h-full bg-error rounded-full w-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="md:col-span-4 space-y-8">
                <div>
                    <h4 class="text-xl font-bold text-on-surface mb-6">Phân tích chi tiêu</h4>
                    <div class="bg-surface-container-low p-8 rounded-3xl space-y-8 border border-white">
                        <div>
                            <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-[0.2em] mb-6">Tổng chi tiêu theo tuần</p>
                            <div class="flex items-end space-x-2.5 h-36">
                                <div class="flex-1 bg-primary/20 rounded-t-lg h-[40%] hover:bg-primary transition-all cursor-pointer"></div>
                                <div class="flex-1 bg-primary/20 rounded-t-lg h-[60%] hover:bg-primary transition-all cursor-pointer"></div>
                                <div class="flex-1 bg-primary/20 rounded-t-lg h-[30%] hover:bg-primary transition-all cursor-pointer"></div>
                                <div class="flex-1 bg-primary/20 rounded-t-lg h-[85%] hover:bg-primary transition-all cursor-pointer"></div>
                                <div class="flex-1 bg-primary rounded-t-lg h-[100%] shadow-lg shadow-primary/30"></div>
                                <div class="flex-1 bg-primary/20 rounded-t-lg h-[50%] hover:bg-primary transition-all cursor-pointer"></div>
                                <div class="flex-1 bg-primary/20 rounded-t-lg h-[45%] hover:bg-primary transition-all cursor-pointer"></div>
                            </div>
                            <div class="flex justify-between mt-4 text-[10px] text-slate-400 font-bold">
                                <span>Th 2</span><span>Th 3</span><span>Th 4</span><span>Th 5</span><span>Th 6</span><span>Th 7</span><span>CN</span>
                            </div>
                        </div>
                        
                        <div class="p-5 bg-white rounded-2xl border border-violet-100/50 shadow-sm relative overflow-hidden">
                            <div class="flex items-center space-x-3 mb-2 relative z-10">
                                <span class="material-symbols-outlined text-primary text-xl">lightbulb</span>
                                <p class="text-sm font-bold text-on-surface">Gợi ý tiết kiệm</p>
                            </div>
                            <p class="text-xs text-slate-500 leading-relaxed relative z-10 font-medium">
                                Bạn thường chi tiêu nhiều vào <span class="text-primary font-bold">Thứ Sáu</span>. Cân nhắc giảm 15% để đạt mục tiêu sớm hơn.
                            </p>
                            <div class="absolute -bottom-2 -right-2 text-primary/5 material-symbols-outlined text-5xl rotate-12">lightbulb</div>
                        </div>
                        
                        <button class="w-full py-4 bg-slate-900 text-white rounded-xl font-bold flex items-center justify-center space-x-2 hover:bg-slate-800 active:scale-[0.98] transition-all shadow-lg">
                            <span>Thiết lập lại mục tiêu</span>
                        </button>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-3xl shadow-sm border border-violet-100/50">
                    <h5 class="font-bold text-on-surface mb-6 flex items-center">
                        Hóa đơn sắp tới
                        <span class="ml-2 w-2 h-2 bg-error rounded-full animate-pulse"></span>
                    </h5>
                    <div class="space-y-6">
                        <div class="flex items-center justify-between group cursor-pointer">
                            <div class="flex items-center space-x-4">
                                <div class="w-10 h-10 rounded-xl bg-surface-container-low flex items-center justify-center group-hover:bg-primary/5 transition-colors">
                                    <span class="material-symbols-outlined text-slate-600 group-hover:text-primary transition-colors">music_note</span>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-on-surface group-hover:text-primary transition-colors">Spotify Premium</p>
                                    <p class="text-[10px] text-slate-400 font-semibold">25 thg 10</p>
                                </div>
                            </div>
                            <p class="text-sm font-extrabold text-on-surface">59.000₫</p>
                        </div>

                        <div class="flex items-center justify-between group cursor-pointer">
                            <div class="flex items-center space-x-4">
                                <div class="w-10 h-10 rounded-xl bg-surface-container-low flex items-center justify-center group-hover:bg-primary/5 transition-colors">
                                    <span class="material-symbols-outlined text-slate-600 group-hover:text-primary transition-colors">bolt</span>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-on-surface group-hover:text-primary transition-colors">Tiền Điện</p>
                                    <p class="text-[10px] text-slate-400 font-semibold">28 thg 10</p>
                                </div>
                            </div>
                            <p class="text-sm font-extrabold text-error">1.250.000₫</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</main>