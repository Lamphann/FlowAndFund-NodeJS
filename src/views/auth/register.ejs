<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Đăng ký | Flow & Fund</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#5b3cdd",
                        "primary-container": "#7459f7",
                        "on-primary": "#ffffff",
                        "surface-container": "#f1ecf3",
                        "surface-container-lowest": "#ffffff",
                        "on-surface": "#1c1b20",
                        "on-surface-variant": "#484555",
                        "outline": "#797587",
                        "error-container": "#ffdad6",
                        "on-error-container": "#93000a",
                        "background": "#fcf8ff",
                    },
                    fontFamily: {
                        "h1": ["Manrope"], "h2": ["Manrope"], "h3": ["Manrope"], "display": ["Manrope"],
                        "body-lg": ["Inter"], "body-md": ["Inter"], "body-sm": ["Inter"], "label-caps": ["Inter"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .soft-shadow { box-shadow: 0 10px 40px rgba(91, 60, 221, 0.1); }
    </style>
</head>
<body class="bg-background font-body-md text-on-surface min-h-screen flex flex-col relative">

    <main class="flex-grow flex items-center justify-center p-4 md:p-8 z-10 relative">
        <div class="w-full max-w-[1100px] grid grid-cols-1 md:grid-cols-2 overflow-hidden bg-surface-container-lowest rounded-[2.5rem] soft-shadow border border-indigo-100 min-h-[640px]">
            
            <div class="hidden md:flex flex-col justify-between p-12 relative overflow-hidden text-white">
                <img src="/images/registerflow.jpg" class="absolute inset-0 w-full h-full object-cover" alt="Background Đăng ký">
                <div class="absolute inset-0 bg-primary/60 mix-blend-multiply"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/60 to-transparent opacity-95"></div>

                <div class="relative z-10">
                    <div class="flex items-center gap-2 mb-10">
                        <span class="material-symbols-outlined text-white text-4xl" data-weight="fill" style="font-variation-settings: 'FILL' 1;">water_drop</span>
                        <span class="font-h1 text-2xl tracking-tight text-white">Flow & Fund</span>
                    </div>
                </div>

                <div class="relative z-10 mb-8">
                    <span class="font-label-caps uppercase tracking-widest opacity-80 mb-2 block">Bắt đầu hành trình</span>
                    <h1 class="font-display text-5xl font-extrabold mb-4 leading-tight">Khơi thông<br>dòng vốn.</h1>
                    <p class="font-body-lg opacity-90">Tạo tài khoản để theo dõi mọi giao dịch, thiết lập ngân sách thông minh và đạt được sự tự do tài chính.</p>
                </div>

                <div class="relative z-10 flex items-center gap-4 pt-4 border-t border-white/20">
                    <div class="flex -space-x-3">
                        <div class="w-10 h-10 rounded-full border-2 border-primary bg-gradient-to-tr from-pink-400 to-orange-300 flex items-center justify-center font-bold text-xs">A</div>
                        <div class="w-10 h-10 rounded-full border-2 border-primary bg-gradient-to-tr from-blue-400 to-emerald-300 flex items-center justify-center font-bold text-xs">B</div>
                        <div class="w-10 h-10 rounded-full border-2 border-primary bg-gradient-to-tr from-purple-400 to-indigo-300 flex items-center justify-center font-bold text-xs">C</div>
                    </div>
                    <span class="font-body-sm opacity-90 font-medium">+10,000 người dùng tin tưởng</span>
                </div>
            </div>

            <div class="p-10 lg:p-14 flex flex-col justify-center bg-white">
                <div class="mb-6">
                    <h2 class="font-h2 text-3xl font-bold text-on-surface mb-2">Tạo tài khoản mới</h2>
                    <p class="font-body-md text-on-surface-variant">Chỉ mất vài giây để bắt đầu.</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="bg-error-container text-on-error-container px-4 py-3 rounded-xl mb-6 flex items-center gap-2 font-body-sm">
                        <span class="material-symbols-outlined text-lg">error</span>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/register" method="POST" class="space-y-4">
                    <div class="space-y-1.5">
                        <label class="font-label-caps text-xs font-bold text-on-surface-variant px-1" for="username">TÊN ĐĂNG NHẬP</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl group-focus-within:text-primary transition-colors">person</span>
                            <input class="w-full pl-12 pr-4 py-3 bg-surface-container rounded-xl border-none focus:ring-2 focus:ring-primary/50 text-on-surface placeholder:text-outline/60 font-body-md transition-all outline-none" 
                                id="username" name="username" placeholder="Nhập tên đăng nhập" type="text" required/>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="font-label-caps text-xs font-bold text-on-surface-variant px-1" for="email">ĐỊA CHỈ EMAIL</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl group-focus-within:text-primary transition-colors">mail</span>
                            <input class="w-full pl-12 pr-4 py-3 bg-surface-container rounded-xl border-none focus:ring-2 focus:ring-primary/50 text-on-surface placeholder:text-outline/60 font-body-md transition-all outline-none" 
                                id="email" name="email" placeholder="example@email.com" type="email" required/>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="font-label-caps text-xs font-bold text-on-surface-variant px-1" for="password">MẬT KHẨU</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl group-focus-within:text-primary transition-colors">lock</span>
                            <input class="w-full pl-12 pr-12 py-3 bg-surface-container rounded-xl border-none focus:ring-2 focus:ring-primary/50 text-on-surface placeholder:text-outline/60 font-body-md transition-all outline-none" 
                                id="password" name="password" placeholder="Tối thiểu 6 ký tự" type="password" required/>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline cursor-pointer hover:text-primary transition-colors select-none" 
                                onclick="togglePassword('password', this)">visibility</span>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="font-label-caps text-xs font-bold text-on-surface-variant px-1" for="confirm">XÁC NHẬN MẬT KHẨU</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl group-focus-within:text-primary transition-colors">lock_reset</span>
                            <input class="w-full pl-12 pr-12 py-3 bg-surface-container rounded-xl border-none focus:ring-2 focus:ring-primary/50 text-on-surface placeholder:text-outline/60 font-body-md transition-all outline-none" 
                                id="confirm" name="confirm" placeholder="Nhập lại mật khẩu" type="password" required/>
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline cursor-pointer hover:text-primary transition-colors select-none" 
                                onclick="togglePassword('confirm', this)">visibility</span>
                        </div>
                    </div>

                    <div class="pt-3">
                        <button class="w-full bg-primary py-4 rounded-xl font-h3 text-white font-bold hover:bg-primary-container shadow-lg shadow-primary/30 transition-all active:scale-[0.98]" type="submit">
                            Hoàn tất đăng ký
                        </button>
                    </div>
                </form>

                <div class="mt-6 text-center border-t border-surface-container pt-5">
                    <p class="font-body-sm text-on-surface-variant">
                        Đã có tài khoản? <a class="font-bold text-primary hover:underline ml-1" href="/login">Đăng nhập tại đây</a>
                    </p>
                </div>
            </div>
        </div>
    </main>

    <script>
        function togglePassword(id, icon) {
            const input = document.getElementById(id);
            if(input.type === "password") {
                input.type = "text"; icon.innerText = "visibility_off";
            } else {
                input.type = "password"; icon.innerText = "visibility";
            }
        }
    </script>
</body>
</html>