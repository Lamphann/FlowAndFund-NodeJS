<%- include('../components/sidebar') %>

<main class="pl-72 min-h-screen">
    <%- include('../components/topbar') %>

    <div class="px-12 pb-16 space-y-10">
        <section class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-gradient-to-br from-primary to-primary-container p-8 rounded-3xl text-on-primary flex flex-col justify-between min-h-[220px] shadow-2xl shadow-primary/20 relative overflow-hidden group">
                <div class="flex justify-between items-start relative z-10">
                    <span class="text-sm font-semibold opacity-90 tracking-wide uppercase">Số dư tổng</span>
                </div>
                <div class="relative z-10">
                    <h3 class="text-4xl font-extrabold tracking-tight mb-3"><%= formatMoney(total) %></h3>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl flex flex-col justify-between min-h-[220px] shadow-sm border border-violet-100/50">
                <div class="flex justify-between items-start">
                    <span class="text-sm font-bold text-slate-400 tracking-wide uppercase">Thu nhập</span>
                </div>
                <div>
                    <h3 class="text-3xl font-extrabold text-tertiary">+ <%= formatMoney(income) %></h3>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl flex flex-col justify-between min-h-[220px] shadow-sm border border-violet-100/50">
                <div class="flex justify-between items-start">
                    <span class="text-sm font-bold text-slate-400 tracking-wide uppercase">Chi tiêu</span>
                </div>
                <div>
                    <h3 class="text-3xl font-extrabold text-error">- <%= formatMoney(expense) %></h3>
                </div>
            </div>
        </section>

        <section class="bg-white p-10 rounded-3xl shadow-sm border border-violet-100/50 mt-8">
            <div class="flex justify-between items-center mb-10">
                <h3 class="text-xl font-extrabold text-on-surface">Giao dịch gần đây</h3>
                <a href="/expenses/transactions" class="text-primary font-bold text-sm hover:underline">Xem tất cả</a>
            </div>
            
            <div class="space-y-2">
                <% if (expenses && expenses.length > 0) { %>
                    <% expenses.forEach(item => { %>
                        <div class="flex items-center justify-between p-5 hover:bg-surface-container-low/50 rounded-2xl transition-all duration-300 group">
                            <div class="flex items-center gap-6">
                                <div class="w-14 h-14 rounded-2xl bg-<%= getCategory(item.category).color %>/10 text-<%= getCategory(item.category).color %> flex items-center justify-center">
                                    <span class="material-symbols-outlined text-2xl">
                                        <%= getCategory(item.category).icon %>
                                    </span>
                                </div>
                                <div>
                                    <p class="font-bold text-lg text-on-surface"><%= item.note %></p>
                                    <p class="text-xs text-<%= getCategory(item.category).color %> font-bold uppercase tracking-wider mt-0.5">
                                        <%= item.category %>
                                    </p>
                                </div>
                            </div>
                            <div class="text-right flex items-center gap-4">
                                <p class="font-extrabold text-lg <%= item.type === 'income' ? 'text-tertiary' : 'text-error' %>">
                                    <%= item.type === 'income' ? '+' : '-' %> <%= formatMoney(item.amount) %>
                                </p>
                                <a href="/expenses/delete/<%= item._id %>" class="text-red-400 hover:text-error transition-colors">
                                    <span class="material-symbols-outlined">delete</span>
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center text-slate-400 py-10 font-medium">Chưa có giao dịch nào.</p>
                <% } %>
            </div>
        </section>
    </div>

    <button onclick="toggleModal('addModal')" class="fixed bottom-10 right-10 w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-primary-container text-white shadow-xl shadow-primary/30 flex items-center justify-center transform hover:scale-110 active:scale-95 transition-all duration-300 z-50">
        <span class="material-symbols-outlined text-3xl">add</span>
    </button>

    <div id="addModal" class="fixed inset-0 bg-on-background/20 backdrop-blur-sm z-[100] hidden flex items-center justify-center transition-all duration-300">
        <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-md border border-violet-100 transform transition-all">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-extrabold text-on-surface">Thêm giao dịch mới</h3>
                <button type="button" onclick="toggleModal('addModal')" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 text-slate-400 hover:text-error transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form action="/expenses/add" method="POST" class="space-y-5">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tên giao dịch</label>
                    <input name="name" type="text" placeholder="Vd: Ăn trưa, Nhận lương..." class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-transparent focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" required>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Số tiền (VNĐ)</label>
                    <input name="amount" type="number" min="1" placeholder="Vd: 50000" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-transparent focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" required>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Loại</label>
                        <select name="type" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-transparent focus:border-primary outline-none cursor-pointer">
                            <option value="Chi">Khoản Chi</option>
                            <option value="Thu">Khoản Thu</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Danh mục</label>
                        <select name="category" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-transparent focus:border-primary outline-none cursor-pointer">
                            <option>Ăn uống</option>
                            <option>Di chuyển</option>
                            <option>Mua sắm</option>
                            <option>Giải trí</option>
                            <option>Sức khỏe</option>
                            <option>Đầu tư</option>
                            <option>Lương</option>
                            <option>Khác</option>
                        </select>
                    </div>
                </div>

                <button type="submit" class="w-full py-4 mt-4 rounded-xl bg-primary text-white font-bold shadow-lg shadow-primary/30 hover:opacity-90 active:scale-[0.98] transition-all">
                    Lưu giao dịch
                </button>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle("hidden");
        }
    </script>
</main>